  <transform>
    <type>TableInput</type>
    <name>source_f_pit_inventory</name>
    <sql>SELECT lwp.x_load_ts AS status_ts, lwp.product_hk, hp.product_id, lwp.warehouse_hk, hw.warehouse_id, lwp.x_record_source, lwp.x_load_ts, slwp.stock_qty, slwp.reorder_point
FROM lnk_warehouse_product lwp
JOIN sat_lnk_warehouse_product slwp ON lwp.lnk_warehouse_product_hk = slwp.lnk_warehouse_product_hk
JOIN hub_warehouse hw ON lwp.warehouse_hk = hw.warehouse_hk
JOIN hub_product hp ON lwp.product_hk = hp.product_hk</sql>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <connection>Vault</connection>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
