  <transform>
    <type>TableInput</type>
    <name>source_f_orders</name>
    <sql>SELECT lo.customer_hk, ho.order_id, hc.customer_id, lo.order_hk, so.order_date, so.shipping_date, so.delivery_date, so.total_amount
FROM lnk_order lo
JOIN sat_order so ON lo.order_hk = so.order_hk
JOIN hub_order ho ON so.order_hk = ho.order_hk
JOIN hub_customer hc ON lo.customer_hk = hc.customer_hk</sql>
