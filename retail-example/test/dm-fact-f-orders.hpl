    <name>source_f_orders</name>
    <sql>SELECT lo.customer_hk, ho.order_id, hc.customer_id, lo.order_hk, so.order_date, so.shipping_date, so.delivery_date, so.total_amount, 'abcd' as degenerate_info, 'a' as j1, 'b' as j2, 'c' as j3
