    </table>
    <table>
      <scdType>TYPE2</scdType>
      <natural_keys>
        <natural_key>
          <fieldName>customer_id</fieldName>
        </natural_key>
      </natural_keys>
      <attributes>
        <attribute>
          <fieldName>cust_segment</fieldName>
