<dimensional-model>
  <filename>/home/matt/git/mattcasters/hop-data-vault/retail-example/models/retail-fact-order.hdm</filename>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>Retail warehouse star schema with date role-playing and extended catalog tables</description>
  <configuration>
    <targetDatabase>Vault</targetDatabase>
    <dimKeyField>dim_key</dimKeyField>
    <versionField>version</versionField>
    <dateFromField>date_from</dateFromField>
    <dateToField>date_to</dateToField>
    <loadDateField>load_dt</loadDateField>
    <currentFlagField>is_current</currentFlagField>
    <openStartSentinel>1900-01-01 00:00:00</openStartSentinel>
    <openEndSentinel>9999-12-31 23:59:59</openEndSentinel>
    <targetTableBatchSize>1000</targetTableBatchSize>
    <targetTableParallelCopies>1</targetTableParallelCopies>
    <target_load_mode>Table Output</target_load_mode>
    <bulkLoadStagingFolder>${java.io.tmpdir}/dv2/bulk/</bulkLoadStagingFolder>
    <bulkLoadDelimiter>,</bulkLoadDelimiter>
    <bulkLoadEnclosure>"</bulkLoadEnclosure>
    <bulkLoadEncoding>UTF-8</bulkLoadEncoding>
    <bulkLoadLocalFileRequired>N</bulkLoadLocalFileRequired>
    <dimensionPipelineNamePrefix>dm-dim-</dimensionPipelineNamePrefix>
    <junkDimensionPipelineNamePrefix>dm-junk-</junkDimensionPipelineNamePrefix>
    <bridgePipelineNamePrefix>dm-bridge-</bridgePipelineNamePrefix>
    <factPipelineNamePrefix>dm-fact-</factPipelineNamePrefix>
    <generatedWorkflowNamePrefix>DM Bulk Update - </generatedWorkflowNamePrefix>
  </configuration>
  <tables>
    <table>
      <dimension_roles>
        <dimension_role>
          <dimensionTableName>dim_order_date</dimensionTableName>
          <foreignKeyColumn>order_date_key</foreignKeyColumn>
          <sourceFieldName>order_date</sourceFieldName>
          <truncateToDateKey>Y</truncateToDateKey>
        </dimension_role>
        <dimension_role>
          <dimensionTableName>dim_shipping_date</dimensionTableName>
          <foreignKeyColumn>shipping_date_key</foreignKeyColumn>
          <sourceFieldName>shipping_date</sourceFieldName>
          <truncateToDateKey>Y</truncateToDateKey>
        </dimension_role>
        <dimension_role>
          <dimensionTableName>dim_delivery_date</dimensionTableName>
          <foreignKeyColumn>delivery_date_key</foreignKeyColumn>
          <sourceFieldName>delivery_date</sourceFieldName>
          <truncateToDateKey>Y</truncateToDateKey>
        </dimension_role>
        <dimension_role>
          <dimensionTableName>dim_order</dimensionTableName>
          <foreignKeyColumn>order_key</foreignKeyColumn>
          <sourceFieldName>order_hk</sourceFieldName>
          <truncateToDateKey>N</truncateToDateKey>
        </dimension_role>
        <dimension_role>
          <dimensionTableName>dim_customer</dimensionTableName>
          <foreignKeyColumn>customer_key</foreignKeyColumn>
          <sourceFieldName>customer_hk</sourceFieldName>
          <truncateToDateKey>N</truncateToDateKey>
        </dimension_role>
      </dimension_roles>
      <measures>
        <measure>
          <fieldName>total_amount</fieldName>
          <additive>Y</additive>
        </measure>
      </measures>
      <tableName>fact_order</tableName>
      <description/>
      <tableType>FACT</tableType>
      <sourceConnection>Vault</sourceConnection>
      <sourceSql>SELECT lo.customer_hk, lo.order_hk, so.order_date, so.shipping_date, so.delivery_date, so.total_amount 
FROM lnk_order lo 
JOIN sat_order so 
  ON lo.order_hk = so.order_hk 
</sourceSql>
      <xloc>560</xloc>
      <yloc>160</yloc>
      <name>fact_order</name>
    </table>
    <table>
      <scdType>TYPE1</scdType>
      <natural_keys>
        <natural_key>
          <fieldName>date_key</fieldName>
        </natural_key>
      </natural_keys>
      <attributes>
        <attribute>
          <fieldName>full_date</fieldName>
          <scdUpdatePolicy>TYPE1</scdUpdatePolicy>
        </attribute>
        <attribute>
          <fieldName>year</fieldName>
          <scdUpdatePolicy>TYPE1</scdUpdatePolicy>
        </attribute>
      </attributes>
      <outriggers/>
