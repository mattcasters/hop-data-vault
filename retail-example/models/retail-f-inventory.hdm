      <tableName>f_pit_inventory</tableName>
      <description/>
      <tableType>FACT</tableType>
      <sourceType>SQL</sourceType>
      <sourceConnection>Vault</sourceConnection>
      <sourceSql>SELECT lwp.x_load_ts AS status_ts, lwp.product_hk, lwp.warehouse_hk, hw.warehouse_id, 
       lwp.x_record_source, lwp.x_load_ts, slwp.stock_qty, slwp.reorder_point  
FROM lnk_warehouse_product lwp 
JOIN sat_lnk_warehouse_product slwp ON lwp.lnk_warehouse_product_hk = slwp.lnk_warehouse_product_hk 
JOIN hub_warehouse hw ON lwp.warehouse_hk = hw.warehouse_hk 
</sourceSql>
