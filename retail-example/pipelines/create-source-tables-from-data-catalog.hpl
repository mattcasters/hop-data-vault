  <transform>
    <type>FilterRows</type>
    <name>Filter rows</name>
    <compare>
      <condition>
        <negated>N</negated>
        <operator>-</operator>
        <leftvalue>namespace</leftvalue>
        <function>=</function>
        <value>
          <name>constant</name>
          <type>String</type>
          <text>hop/retail-example/sources</text>
          <length>-1</length>
          <precision>-1</precision>
          <isnull>N</isnull>
          <mask/>
        </value>
        <conditions>
          <condition>
            <negated>N</negated>
            <operator>-</operator>
            <leftvalue>namespace</leftvalue>
            <function>=</function>
            <value>
              <name>constant</name>
              <type>String</type>
              <text>hop/retail-example/sources</text>
              <length>-1</length>
              <precision>-1</precision>
              <isnull>N</isnull>
              <mask/>
            </value>
            <conditions/>
          </condition>
          <condition>
            <negated>N</negated>
            <operator>AND</operator>
            <leftvalue>name</leftvalue>
            <function>STARTS WITH</function>
            <value>
              <name>constant</name>
              <type>String</type>
              <text>E2E</text>
              <length>-1</length>
              <precision>-1</precision>
              <isnull>N</isnull>
              <mask/>
            </value>
            <conditions>
              <condition>
                <negated>N</negated>
                <operator>AND</operator>
                <leftvalue>dv_source_type</leftvalue>
                <function>=</function>
                <value>
                  <name>constant</name>
                  <type>String</type>
                  <text>DATABASE</text>
                  <length>-1</length>
                  <precision>-1</precision>
                  <isnull>N</isnull>
                  <mask/>
                </value>
                <conditions/>
              </condition>
            </conditions>
          </condition>
        </conditions>
      </condition>
    </compare>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>400</xloc>
      <yloc>80</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>SelectValues</type>
