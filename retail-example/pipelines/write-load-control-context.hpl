<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>-1</pipeline_status>
    <parameters/>
    <name>write-load-control-context</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/07/03 00:00:00.000</created_date>
    <modified_date>2026/07/03 00:00:00.000</modified_date>
  </info>
  <transform>
    <type>TableInput</type>
    <name>read_load_control</name>
    <sql>SELECT progress_date::text AS progress_date, period_months
FROM load_control
WHERE topic = 'retail'</sql>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <connection>Vault</connection>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>160</xloc>
      <yloc>64</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>TextFileOutput</type>
    <name>write_load_control_context</name>
    <compression>None</compression>
    <create_parent_folder>Y</create_parent_folder>
    <separator>,</separator>
    <enclosure/>
    <enclosure_forced>N</enclosure_forced>
    <enclosure_fix_disabled>N</enclosure_fix_disabled>
    <header>N</header>
    <footer>N</footer>
    <format>UNIX</format>
    <encoding>UTF-8</encoding>
    <endedLine/>
    <fileNameInField>N</fileNameInField>
    <fileNameField/>
    <schema_definition/>
    <ignore_fields>N</ignore_fields>
    <file>
      <name>${PROJECT_HOME}/files/.load-control</name>
      <do_not_open_new_file_init>N</do_not_open_new_file_init>
      <extension/>
      <append>N</append>
      <split>N</split>
      <haspartno>N</haspartno>
      <add_date>N</add_date>
      <add_time>N</add_time>
      <SpecifyFormat>N</SpecifyFormat>
      <date_time_format/>
      <add_to_result_filenames>N</add_to_result_filenames>
      <pad>N</pad>
      <fast_dump>N</fast_dump>
      <splitevery/>
    </file>
    <fields>
      <field>
        <name>progress_date</name>
        <type>String</type>
        <format/>
        <length>-1</length>
        <precision>-1</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <trim_type>none</trim_type>
        <nullif/>
      </field>
      <field>
        <name>period_months</name>
        <type>Integer</type>
        <format>0</format>
        <length>-1</length>
        <precision>0</precision>
        <currency>$</currency>
        <decimal>.</decimal>
        <group>,</group>
        <trim_type>none</trim_type>
        <nullif/>
      </field>
    </fields>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>400</xloc>
      <yloc>64</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>read_load_control</from>
      <to>write_load_control_context</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads/>
  <attributes/>
  <transform_error_handling/>
</pipeline>