<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0 http://maven.apache.org/xsd/assembly-2.2.0.xsd">
    <id>hop-misc-datavault</id>
    <formats>
        <format>zip</format>
    </formats>
    <baseDirectory>.</baseDirectory>
    <files>
        <file>
            <source>${project.basedir}/src/main/resources/version.xml</source>
            <outputDirectory>plugins/misc/datavault/</outputDirectory>
            <filtered>true</filtered>
        </file>
        <file>
            <source>${project.basedir}/README.md</source>
            <outputDirectory>plugins/misc/datavault/</outputDirectory>
            <filtered>true</filtered>
        </file>
        <file>
            <source>${project.basedir}/src/main/resources/dependencies.xml</source>
            <outputDirectory>plugins/misc/datavault/</outputDirectory>
            <filtered>true</filtered>
        </file>
    </files>
    <dependencySets>
        <dependencySet>
            <includes>
                <include>org.apache.hop:hop-datavault:jar</include>
            </includes>
            <outputDirectory>plugins/misc/datavault/</outputDirectory>
        </dependencySet>
        <dependencySet>
            <includes>
                <include>org.eclipse.elk:*</include>
                <include>org.eclipse.emf:*</include>
                <include>org.jspecify:*</include>
            </includes>
            <outputDirectory>plugins/misc/datavault/lib</outputDirectory>
            <useTransitiveDependencies>true</useTransitiveDependencies>
            <useProjectArtifact>false</useProjectArtifact>
        </dependencySet>
        <dependencySet>
            <includes>
                <include>org.apache.iceberg:iceberg-hive-runtime</include>
                <include>org.apache.hadoop:*</include>
                <include>software.amazon.awssdk:*</include>
                <include>software.amazon.eventstream:*</include>
                <include>org.apache.httpcomponents:*</include>
                <include>org.apache.httpcomponents.client5:*</include>
                <include>com.github.ben-manes.caffeine:*</include>
                <include>io.airlift:aircompressor</include>
                <include>org.roaringbitmap:*</include>
            </includes>
            <outputDirectory>plugins/misc/datavault/lib</outputDirectory>
            <useTransitiveDependencies>true</useTransitiveDependencies>
            <useProjectArtifact>false</useProjectArtifact>
        </dependencySet>
        <dependencySet>
            <includes>
                <include>org.apache.hop:hop-transform-checksum:jar</include>
                <include>org.apache.hop:hop-transform-constant:jar</include>
                <include>org.apache.hop:hop-transform-filterrows:jar</include>
                <include>org.apache.hop:hop-transform-groupby:jar</include>
                <include>org.apache.hop:hop-transform-append:jar</include>
                <include>org.apache.hop:hop-transform-mergerows:jar</include>
                <include>org.apache.hop:hop-transform-selectvalues:jar</include>
                <include>org.apache.hop:hop-transform-sort:jar</include>
                <include>org.apache.hop:hop-transform-sql:jar</include>
                <include>org.apache.hop:hop-transform-textfile:jar</include>
                <include>org.apache.hop:hop-transform-filemetadata:jar</include>
                <include>org.apache.hop:hop-transform-metastructure:jar</include>
                <include>org.apache.hop:hop-transform-uniquerowsbyhashset:jar</include>
                <include>org.apache.hop:hop-transform-tableinput:jar</include>
                <include>org.apache.hop:hop-transform-tableoutput:jar</include>
                <include>org.apache.hop:hop-transform-update:jar</include>
                <include>org.apache.hop:hop-transform-getfilenames:jar</include>
                <include>org.apache.hop:hop-transform-pipelineexecutor:jar</include>
                <include>org.apache.hop:hop-transform-languagemodelchat:jar</include>
            </includes>
            <outputDirectory>plugins/misc/datavault/lib</outputDirectory>
        </dependencySet>
    </dependencySets>
</assembly>
