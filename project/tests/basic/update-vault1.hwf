      <sql>DROP TABLE IF EXISTS "customer"
;
CREATE TABLE customer
(
  customer_id INTEGER
, "name" VARCHAR(50)
, email VARCHAR(50)
, address VARCHAR(50)
, city VARCHAR(50)
, load_date TIMESTAMP
, record_source VARCHAR(20)
)
;

DROP TABLE IF EXISTS "product"
;
CREATE TABLE product
(
  product_id VARCHAR(7)
, product_name VARCHAR(50)
, category VARCHAR(50)
, unit_price NUMERIC(9, 2)
, load_date TIMESTAMP
, record_source VARCHAR(20)
)
;

DROP TABLE IF EXISTS "order"
;
CREATE TABLE "order"
(
  order_id VARCHAR(7)
, customer_id INTEGER
, product_id VARCHAR(7)
, quantity INTEGER
, unit_price NUMERIC(9, 2)
, order_date TIMESTAMP
, load_date TIMESTAMP
, record_source VARCHAR(20)
)
;
</sql>
