<?xml version="1.0" encoding="UTF-8"?>
<workflow>
  <name>publish-vault1-catalog</name>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>Catalog-only test: publish vault1 target table record definitions without loading data.</description>
  <created_user>-</created_user>
  <modified_user>-</modified_user>
  <created_date>2026/06/22 12:00:00.000</created_date>
  <modified_date>2026/06/22 12:00:00.000</modified_date>
  <workflow_version/>
  <actions>
    <action>
      <name>Start</name>
      <description/>
      <type>SPECIAL</type>
      <attributes/>
      <xloc>48</xloc>
      <yloc>48</yloc>
      <parallel>N</parallel>
    </action>
    <action>
      <dataVaultModelFile>${PROJECT_HOME}/tests/basic/vault1.hdv</dataVaultModelFile>
      <pipelineRunConfiguration>local</pipelineRunConfiguration>
      <logModelCheckFailures>Y</logModelCheckFailures>
      <abortOnModelCheckFailures>Y</abortOnModelCheckFailures>
      <detailedDataTypeChecking>Y</detailedDataTypeChecking>
      <parallelPipelineCopies>1</parallelPipelineCopies>
      <publishToCatalog>Y</publishToCatalog>
      <dataCatalogConnection>local-catalog</dataCatalogConnection>
      <updateTargetDatabaseStructure>N</updateTargetDatabaseStructure>
      <failIfDdlNeeded>N</failIfDdlNeeded>
      <ensureSpecialRecords>N</ensureSpecialRecords>
      <doNotUpdateTargetDatabase>Y</doNotUpdateTargetDatabase>
      <name>publish vault1 catalog</name>
      <description>Upsert DV table and source record definitions into local-catalog.</description>
      <type>DATA_VAULT_UPDATE</type>
      <attributes/>
      <xloc>320</xloc>
      <yloc>48</yloc>
      <parallel>N</parallel>
    </action>
    <action>
      <name>Success</name>
      <description/>
      <type>SUCCESS</type>
      <attributes/>
      <xloc>592</xloc>
      <yloc>48</yloc>
      <parallel>N</parallel>
    </action>
  </actions>
  <hops>
    <hop>
      <from>Start</from>
      <to>publish vault1 catalog</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
      <unconditional>Y</unconditional>
    </hop>
    <hop>
      <from>publish vault1 catalog</from>
      <to>Success</to>
      <enabled>Y</enabled>
      <evaluation>Y</evaluation>
      <unconditional>N</unconditional>
    </hop>
  </hops>
</workflow>