<data-vault-model>
  <name>link-satellite</name>
  <filename>${PROJECT_HOME}/tests/link-satellite/link-satellite.hdv</filename>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>Link satellite test case: customer-product relationship with quantity and discount attributes</description>
  <configuration>vault-config</configuration>
  <tables>
    <table>
      <businessKeys>
        <name>customer_id</name>
        <description>Customer business key</description>
        <dataType>Integer</dataType>
        <length>9</length>
        <sourceFieldName>customer_id</sourceFieldName>
        <recordSourceName>CRM-customer-product</recordSourceName>
      </businessKeys>
      <hashKeyFieldName>customer_hk</hashKeyFieldName>
      <recordSourceFieldName/>
      <recordSources>
        <recordSource>CRM-customer-product</recordSource>
      </recordSources>
      <tableName>hub_customer_ls</tableName>
      <description>Hub for customers in the link satellite test case</description>
      <tableType>HUB</tableType>
      <xloc>48</xloc>
      <yloc>48</yloc>
      <name>hub_customer_ls</name>
      <virtualPath/>
    </table>
    <table>
      <businessKeys>
        <name>product_id</name>
        <description>Product business key</description>
        <dataType>String</dataType>
        <length>7</length>
        <sourceFieldName>product_id</sourceFieldName>
        <recordSourceName>CRM-customer-product</recordSourceName>
      </businessKeys>
      <hashKeyFieldName>product_hk</hashKeyFieldName>
      <recordSourceFieldName/>
      <recordSources>
        <recordSource>CRM-customer-product</recordSource>
      </recordSources>
      <tableName>hub_product_ls</tableName>
      <description>Hub for products in the link satellite test case</description>
      <tableType>HUB</tableType>
      <xloc>48</xloc>
      <yloc>192</yloc>
      <name>hub_product_ls</name>
      <virtualPath/>
    </table>
    <table>
      <hubNames>hub_customer_ls</hubNames>
      <hubNames>hub_product_ls</hubNames>
      <linkSatelliteNames>sat_lnk_customer_product</linkSatelliteNames>
      <linkHubSources>
        <linkHubSource>
          <source>CRM-customer-product</source>
          <hubSourceKeyFields>
            <hubSourceKeyField>
              <hubName>hub_customer_ls</hubName>
              <businessKeySources>
                <businessKeySource>
                  <businessKeyField>customer_id</businessKeyField>
                  <sourceFieldName>customer_id</sourceFieldName>
                </businessKeySource>
              </businessKeySources>
              <drivingKeySources/>
            </hubSourceKeyField>
            <hubSourceKeyField>
              <hubName>hub_product_ls</hubName>
              <businessKeySources>
                <businessKeySource>
                  <businessKeyField>product_id</businessKeyField>
                  <sourceFieldName>product_id</sourceFieldName>
                </businessKeySource>
              </businessKeySources>
              <drivingKeySources/>
            </hubSourceKeyField>
          </hubSourceKeyFields>
        </linkHubSource>
      </linkHubSources>
      <linkSatelliteSources>
        <linkSatelliteSource>
          <source>CRM-customer-product</source>
          <satelliteSourceKeyFields>
            <satelliteSourceKeyField>
              <satelliteName>sat_lnk_customer_product</satelliteName>
              <attributeSources>
                <attributeSource>
                  <attributeField>quantity</attributeField>
                  <sourceFieldName>quantity</sourceFieldName>
                </attributeSource>
                <attributeSource>
                  <attributeField>discount_pct</attributeField>
                  <sourceFieldName>discount_pct</sourceFieldName>
                </attributeSource>
              </attributeSources>
              <drivingKeySources/>
            </satelliteSourceKeyField>
          </satelliteSourceKeyFields>
        </linkSatelliteSource>
      </linkSatelliteSources>
      <linkHashKeyFieldName>lnk_customer_product_hk</linkHashKeyFieldName>
      <hubSourceKeyFields/>
      <hasDescriptiveAttributes>Y</hasDescriptiveAttributes>
      <recordSourceFieldName/>
      <tableName>lnk_customer_product</tableName>
      <description>Customer-product purchase relationship</description>
      <tableType>LINK</tableType>
      <xloc>272</xloc>
      <yloc>120</yloc>
      <name>lnk_customer_product</name>
      <virtualPath/>
    </table>
    <table>
      <hub/>
      <link>lnk_customer_product</link>
      <attributes>
        <name>quantity</name>
        <description>Quantity purchased</description>
        <dataType>Integer</dataType>
        <length>9</length>
        <precision/>
        <includeInChangeDataCapture>Y</includeInChangeDataCapture>
      </attributes>
      <attributes>
        <name>discount_pct</name>
        <description>Discount percentage applied</description>
        <dataType>Number</dataType>
        <length>5</length>
        <precision>2</precision>
        <includeInChangeDataCapture>Y</includeInChangeDataCapture>
      </attributes>
      <drivingKey/>
      <drivingKeySourceField/>
      <recordSource>CRM-customer-product</recordSource>
      <tableName>sat_lnk_customer_product</tableName>
      <description>Link satellite: quantity and discount for each customer-product relationship</description>
      <tableType>SATELLITE</tableType>
      <xloc>496</xloc>
      <yloc>120</yloc>
      <name>sat_lnk_customer_product</name>
      <virtualPath/>
    </table>
  </tables>
</data-vault-model>