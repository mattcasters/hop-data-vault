  <transform>
    <type>TableInput</type>
    <name>sts_customer</name>
    <sql>SELECT
  customer_hk
, record_status
, x_record_source
FROM sts_customer
WHERE x_load_ts = (SELECT MAX(x_load_ts) FROM sts_customer)
ORDER BY customer_hk, record_status
</sql>
    <limit>0</limit>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <connection>Vault</connection>
