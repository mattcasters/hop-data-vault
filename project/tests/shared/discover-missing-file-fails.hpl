<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>discover-missing-file-fails</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
  </info>
  <transform>
    <type>RecordDefinitionOutput</type>
    <name>Discover missing file</name>
    <catalog_connection>local-catalog</catalog_connection>
    <record_definition_type>DV_SOURCE</record_definition_type>
    <select_from_input>N</select_from_input>
    <namespace_value>hop/project/sources</namespace_value>
    <name_value>TEST-missing-file</name_value>
    <write_to_catalog>Y</write_to_catalog>
    <fail_if_no_fields>Y</fail_if_no_fields>
    <source_type>CSV</source_type>
    <file_path>${PROJECT_HOME}/files/does-not-exist/missing.csv</file_path>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
    </partitioning>
  </transform>
</pipeline>