<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters>
      <parameter>
        <name>PARQUET_FILE</name>
        <default_value>${PROJECT_HOME}/files/parquet-basic/customer_load1.parquet</default_value>
      </parameter>
      <parameter>
        <name>CATALOG_NAME</name>
        <default_value>TEST-discover-parquet-output</default_value>
      </parameter>
      <parameter>
        <name>CATALOG_NAMESPACE</name>
        <default_value>hop/project/sources</default_value>
      </parameter>
    </parameters>
    <name>discover-parquet-to-catalog</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/06/23 12:28:25.390</created_date>
    <modified_date>2026/06/23 12:28:25.390</modified_date>
  </info>
  <transform>
    <type>RecordDefinitionOutput</type>
    <name>Discover Parquet to catalog</name>
    <catalog_connection>local-catalog</catalog_connection>
    <record_definition_type>DV_SOURCE</record_definition_type>
    <select_from_input>N</select_from_input>
    <namespace_value>${CATALOG_NAMESPACE}</namespace_value>
    <name_value>${CATALOG_NAME}</name_value>
    <description_value>Discovered by Record Definition Output Parquet test</description_value>
    <write_to_catalog>Y</write_to_catalog>
    <fail_if_no_fields>Y</fail_if_no_fields>
    <source_type>PARQUET</source_type>
    <file_path>${PARQUET_FILE}</file_path>
    <include_subfolders>N</include_subfolders>
    <delivery_type>CHANGES_ONLY</delivery_type>
    <field_count_field>field_count</field_count_field>
    <written_to_catalog_field>written_to_catalog</written_to_catalog_field>
    <catalog_namespace_field>catalog_namespace</catalog_namespace_field>
    <catalog_name_field>catalog_name</catalog_name_field>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>96</xloc>
      <yloc>32</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>FilterRows</type>
    <name>Assert discovered</name>
    <compare>
      <condition>
        <negated>N</negated>
        <operator>AND</operator>
        <function>=</function>
        <conditions>
          <condition>
            <negated>N</negated>
            <operator>-</operator>
            <leftvalue>written_to_catalog</leftvalue>
            <function>=</function>
            <value>
              <name>constant</name>
              <type>Boolean</type>
              <text>Y</text>
              <length>0</length>
              <precision>0</precision>
              <isnull>N</isnull>
            </value>
            <conditions/>
          </condition>
          <condition>
            <negated>N</negated>
            <operator>-</operator>
            <leftvalue>field_count</leftvalue>
            <function>&gt;</function>
            <value>
              <name>constant</name>
              <type>Integer</type>
              <text>0</text>
              <length>0</length>
              <precision>0</precision>
              <isnull>N</isnull>
            </value>
            <conditions/>
          </condition>
        </conditions>
      </condition>
    </compare>
    <send_true_to>OK</send_true_to>
    <send_false_to/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>352</xloc>
      <yloc>32</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Dummy</type>
    <name>OK</name>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>528</xloc>
      <yloc>32</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>Discover Parquet to catalog</from>
      <to>Assert discovered</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Assert discovered</from>
      <to>OK</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads/>
  <attributes/>
  <transform_error_handling/>
</pipeline>
