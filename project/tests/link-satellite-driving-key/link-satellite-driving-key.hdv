<data-vault-model>
  <name>link-satellite-driving-key</name>
  <filename>${PROJECT_HOME}/tests/link-satellite-driving-key/link-satellite-driving-key.hdv</filename>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>Multi-active link satellite test: customer-product relationship with line_number driving key</description>
  <configuration>
    <targetDatabase>Vault</targetDatabase>
    <hashAlgorithm>MD5</hashAlgorithm>
    <hashKeyDataType>STRING</hashKeyDataType>
    <generateUnknownRecord>Y</generateUnknownRecord>
    <unknownBusinessKeyValue>N/A</unknownBusinessKeyValue>
    <unknownHashKeyValue>00000000000000000000000000000000</unknownHashKeyValue>
    <unknownLinkHashKeyValue>00000000000000000000000000000000</unknownLinkHashKeyValue>
    <unknownRecordSource>UNKNOWN</unknownRecordSource>
    <generateInvalidRecord>Y</generateInvalidRecord>
    <invalidBusinessKeyValue>INVALID</invalidBusinessKeyValue>
    <invalidHashKeyValue>FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF</invalidHashKeyValue>
    <invalidLinkHashKeyValue>FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF</invalidLinkHashKeyValue>
    <invalidRecordSource>INVALID</invalidRecordSource>
    <hashContentCasing>UPPER</hashContentCasing>
    <businessKeyDelimiter/>
    <hashContentPrefix/>
    <nullPlaceholder/>
    <hashContentSuffix/>
    <trimBusinessKeys>N</trimBusinessKeys>
    <loadDateField>x_load_ts</loadDateField>
    <loadEndDateField/>
    <recordSourceField>x_record_source</recordSourceField>
    <recordSourceFieldLength>100</recordSourceFieldLength>
    <useLoadEndDate>N</useLoadEndDate>
    <targetTableBatchSize>1000</targetTableBatchSize>
    <hubPipelineNamePrefix>hub-</hubPipelineNamePrefix>
    <linkPipelineNamePrefix>link-</linkPipelineNamePrefix>
    <satellitePipelineNamePrefix>sat-</satellitePipelineNamePrefix>
    <targetTableParallelCopies>${OUTPUT_COPIES}</targetTableParallelCopies>
  </configuration>
  <tables>
    <table>
      <businessKeys>
        <name>customer_id</name>
        <description>Customer business key</description>
        <dataType>Integer</dataType>
        <length>9</length>
        <sourceFieldName>customer_id</sourceFieldName>
        <recordSourceName>CRM-customer-product-line</recordSourceName>
      </businessKeys>
      <hashKeyFieldName>customer_hk</hashKeyFieldName>
      <recordSourceFieldName/>
      <recordSources>
        <recordSource>CRM-customer-product-line</recordSource>
      </recordSources>
      <tableName>hub_customer_lsd</tableName>
      <description>Hub for customers in the link satellite driving key test case</description>
      <tableType>HUB</tableType>
      <xloc>80</xloc>
      <yloc>64</yloc>
      <name>hub_customer_lsd</name>
      <virtualPath/>
    </table>
    <table>
      <businessKeys>
        <name>product_id</name>
        <description>Product business key</description>
        <dataType>String</dataType>
        <length>7</length>
        <sourceFieldName>product_id</sourceFieldName>
        <recordSourceName>CRM-customer-product-line</recordSourceName>
      </businessKeys>
      <hashKeyFieldName>product_hk</hashKeyFieldName>
      <recordSourceFieldName/>
      <recordSources>
        <recordSource>CRM-customer-product-line</recordSource>
      </recordSources>
      <tableName>hub_product_lsd</tableName>
      <description>Hub for products in the link satellite driving key test case</description>
      <tableType>HUB</tableType>
      <xloc>80</xloc>
      <yloc>208</yloc>
      <name>hub_product_lsd</name>
      <virtualPath/>
    </table>
    <table>
      <hubNames>hub_customer_lsd</hubNames>
      <hubNames>hub_product_lsd</hubNames>
      <linkSatelliteNames>sat_lnk_customer_product_lsd</linkSatelliteNames>
      <linkHubSources>
        <linkHubSource>
          <source>CRM-customer-product-line</source>
          <hubSourceKeyFields>
            <hubSourceKeyField>
              <hubName>hub_customer_lsd</hubName>
              <businessKeySources>
                <businessKeySource>
                  <businessKeyField>customer_id</businessKeyField>
                  <sourceFieldName>customer_id</sourceFieldName>
                </businessKeySource>
              </businessKeySources>
              <drivingKeySources/>
            </hubSourceKeyField>
            <hubSourceKeyField>
              <hubName>hub_product_lsd</hubName>
              <businessKeySources>
                <businessKeySource>
                  <businessKeyField>product_id</businessKeyField>
                  <sourceFieldName>product_id</sourceFieldName>
                </businessKeySource>
              </businessKeySources>
              <drivingKeySources/>
            </hubSourceKeyField>
          </hubSourceKeyFields>
        </linkHubSource>
      </linkHubSources>
      <linkSatelliteSources>
        <linkSatelliteSource>
          <source>CRM-customer-product-line</source>
          <satelliteSourceKeyFields>
            <satelliteSourceKeyField>
              <satelliteName>sat_lnk_customer_product_lsd</satelliteName>
              <attributeSources>
                <attributeSource>
                  <attributeField>quantity</attributeField>
                  <sourceFieldName>quantity</sourceFieldName>
                </attributeSource>
                <attributeSource>
                  <attributeField>discount_pct</attributeField>
                  <sourceFieldName>discount_pct</sourceFieldName>
                </attributeSource>
              </attributeSources>
              <drivingKeySources>
                <drivingKeySource>
                  <drivingKey>line_number</drivingKey>
                  <sourceField>line_number</sourceField>
                </drivingKeySource>
              </drivingKeySources>
            </satelliteSourceKeyField>
          </satelliteSourceKeyFields>
        </linkSatelliteSource>
      </linkSatelliteSources>
      <linkHashKeyFieldName>lnk_customer_product_lsd_hk</linkHashKeyFieldName>
      <hubSourceKeyFields/>
      <hasDescriptiveAttributes>Y</hasDescriptiveAttributes>
      <recordSourceFieldName/>
      <tableName>lnk_customer_product_lsd</tableName>
      <description>Customer-product purchase relationship</description>
      <tableType>LINK</tableType>
      <xloc>336</xloc>
      <yloc>128</yloc>
      <name>lnk_customer_product_lsd</name>
      <virtualPath/>
    </table>
    <table>
      <hub/>
      <link>lnk_customer_product_lsd</link>
      <attributes>
        <name>quantity</name>
        <description>Quantity purchased on this line</description>
        <dataType>Integer</dataType>
        <length>9</length>
        <precision/>
        <includeInChangeDataCapture>Y</includeInChangeDataCapture>
      </attributes>
      <attributes>
        <name>discount_pct</name>
        <description>Discount percentage applied</description>
        <dataType>Number</dataType>
        <length>5</length>
        <precision>2</precision>
        <includeInChangeDataCapture>Y</includeInChangeDataCapture>
      </attributes>
      <drivingKey>line_number</drivingKey>
      <drivingKeySourceField>line_number</drivingKeySourceField>
      <recordSource>CRM-customer-product-line</recordSource>
      <tableName>sat_lnk_customer_product_lsd</tableName>
      <description>Multi-active link satellite: quantity and discount per customer-product line</description>
      <tableType>SATELLITE</tableType>
      <xloc>592</xloc>
      <yloc>128</yloc>
      <name>sat_lnk_customer_product_lsd</name>
      <virtualPath/>
    </table>
  </tables>
  <notes/>
</data-vault-model>