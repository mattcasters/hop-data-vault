<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>-1</pipeline_status>
    <parameters/>
    <name>validate-sat-customer-led</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <created_user>-</created_user>
    <modified_user>-</modified_user>
    <created_date>2026/06/18 12:00:00.000</created_date>
    <modified_date>2026/06/18 12:00:00.000</modified_date>
  </info>
  <transform>
    <type>TableInput</type>
    <name>sat_customer_led</name>
    <sql>SELECT
  customer_hk
, name
, email
, x_record_source
, x_load_ts
, x_load_end_ts
FROM sat_customer_led
ORDER BY customer_hk, x_load_ts
</sql>
    <limit>0</limit>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <connection>Vault</connection>
    <lookup/>
    <sql_from_file/>
    <distribute>N</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>128</xloc>
      <yloc>96</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>FilterRows</type>
    <name>has load date</name>
    <compare>
      <condition>
        <negated>N</negated>
        <operator>-</operator>
        <leftvalue>x_load_ts</leftvalue>
        <function>IS NOT NULL</function>
        <conditions/>
      </condition>
    </compare>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>272</xloc>
      <yloc>96</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>FilterRows</type>
    <name>has record source</name>
    <compare>
      <condition>
        <negated>N</negated>
        <operator>-</operator>
        <leftvalue>x_record_source</leftvalue>
        <function>IS NOT NULL</function>
        <conditions/>
      </condition>
    </compare>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>416</xloc>
      <yloc>96</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Dummy</type>
    <name>Validate</name>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>576</xloc>
      <yloc>96</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>FilterRows</type>
    <name>has load end date</name>
    <compare>
      <condition>
        <negated>N</negated>
        <operator>-</operator>
        <leftvalue>x_load_end_ts</leftvalue>
        <function>IS NOT NULL</function>
        <conditions/>
      </condition>
    </compare>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>272</xloc>
      <yloc>208</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>FilterRows</type>
    <name>end_ts > ts</name>
    <compare>
      <condition>
        <negated>N</negated>
        <operator>-</operator>
        <leftvalue>x_load_end_ts</leftvalue>
        <function>&gt;</function>
        <rightvalue>x_load_ts</rightvalue>
        <conditions/>
      </condition>
    </compare>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>400</xloc>
      <yloc>208</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>GroupBy</type>
    <name>count</name>
    <all_rows>N</all_rows>
    <directory>${java.io.tmpdir}</directory>
    <prefix>grp</prefix>
    <ignore_aggregate>N</ignore_aggregate>
    <group/>
    <fields>
      <field>
        <aggregate>count</aggregate>
        <subject/>
        <type>COUNT_ANY</type>
        <valuefield/>
      </field>
    </fields>
    <add_linenr>N</add_linenr>
    <linenr_fieldname/>
    <give_back_row>N</give_back_row>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>512</xloc>
      <yloc>208</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>FilterRows</type>
    <name>count&lt;>1</name>
    <compare>
      <condition>
        <negated>N</negated>
        <operator>-</operator>
        <leftvalue>count</leftvalue>
        <function>&lt;></function>
        <value>
          <name>constant</name>
          <type>Integer</type>
          <text>1</text>
          <length>-1</length>
          <precision>0</precision>
          <isnull>N</isnull>
          <mask>####0;-####0</mask>
        </value>
        <conditions/>
      </condition>
    </compare>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>608</xloc>
      <yloc>208</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <transform>
    <type>Abort</type>
    <name>unexpected amount of rows found</name>
    <row_threshold>0</row_threshold>
    <message>exactly one row with end_ts > ts was expected</message>
    <always_log_rows>Y</always_log_rows>
    <abort_option>ABORT_WITH_ERROR</abort_option>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>768</xloc>
      <yloc>208</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
  <order>
    <hop>
      <from>sat_customer_led</from>
      <to>has load date</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>has load date</from>
      <to>has record source</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>has record source</from>
      <to>Validate</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>sat_customer_led</from>
      <to>has load end date</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>has load end date</from>
      <to>end_ts > ts</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>end_ts > ts</from>
      <to>count</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>count</from>
      <to>count&lt;>1</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>count&lt;>1</from>
      <to>unexpected amount of rows found</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <notepads/>
  <attributes/>
  <transform_error_handling/>
</pipeline>
