    <action>
      <script>var dbType = parent_workflow.getVariable("DB_TYPE");
if (dbType == null) {
  dbType = "";
}
// Run multi-satellite BV only for Postgres (or unset local default)
dbType == "" || dbType == "postgres";
</script>
