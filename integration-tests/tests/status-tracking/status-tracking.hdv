<data-vault-model>
  <filename>/home/matt/git/mattcasters/hop-data-vault/integration-tests/tests//status-tracking/status-tracking.hdv</filename>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>Status Tracking Satellite test: hub + descriptive satellite + STS on FULL_SNAPSHOT source</description>
  <configuration>
    <targetDatabase>Vault</targetDatabase>
    <dataCatalogConnection>local-catalog</dataCatalogConnection>
    <hashAlgorithm>MD5</hashAlgorithm>
    <hashKeyDataType>STRING</hashKeyDataType>
    <generateUnknownRecord>Y</generateUnknownRecord>
    <unknownBusinessKeyValue>N/A</unknownBusinessKeyValue>
    <unknownHashKeyValue>00000000000000000000000000000000</unknownHashKeyValue>
    <unknownLinkHashKeyValue>00000000000000000000000000000000</unknownLinkHashKeyValue>
    <unknownRecordSource>UNKNOWN</unknownRecordSource>
    <generateInvalidRecord>Y</generateInvalidRecord>
    <invalidBusinessKeyValue>INVALID</invalidBusinessKeyValue>
    <invalidHashKeyValue>FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF</invalidHashKeyValue>
    <invalidLinkHashKeyValue>FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF</invalidLinkHashKeyValue>
    <invalidRecordSource>INVALID</invalidRecordSource>
    <hashContentCasing>UPPER</hashContentCasing>
    <businessKeyDelimiter>||</businessKeyDelimiter>
    <hashContentPrefix/>
    <nullPlaceholder>^^</nullPlaceholder>
    <hashContentSuffix/>
    <trimBusinessKeys>N</trimBusinessKeys>
    <loadDateField>x_load_ts</loadDateField>
    <loadEndDateField>LOAD_END_DATE</loadEndDateField>
    <recordSourceField>x_record_source</recordSourceField>
    <recordSourceFieldLength>100</recordSourceFieldLength>
    <useLoadEndDate>N</useLoadEndDate>
    <targetTableBatchSize>1000</targetTableBatchSize>
    <targetTableParallelCopies>${OUTPUT_COPIES}</targetTableParallelCopies>
    <execution_log_level>Minimal</execution_log_level>
    <generatedPipelineFolder/>
    <hubPipelineNamePrefix>hub-</hubPipelineNamePrefix>
    <linkPipelineNamePrefix>link-</linkPipelineNamePrefix>
    <satellitePipelineNamePrefix>sat-</satellitePipelineNamePrefix>
    <stsPipelineNamePrefix>sts-</stsPipelineNamePrefix>
  </configuration>
  <tables>
    <table>
      <businessKeys>
        <name>customer_id</name>
        <description>Customer business key</description>
        <dataType>Integer</dataType>
        <length>9</length>
        <sourceFieldName>customer_id</sourceFieldName>
        <recordSourceName>CRM-customer</recordSourceName>
      </businessKeys>
      <hashKeyFieldName>customer_hk</hashKeyFieldName>
      <recordSourceFieldName/>
      <recordSources>
        <recordSource>CRM-customer</recordSource>
      </recordSources>
      <tableName>hub_customer_sts</tableName>
      <description>Hub for STS test</description>
      <tableType>HUB</tableType>
      <xloc>64</xloc>
      <yloc>48</yloc>
      <name>hub_customer_sts</name>
      <virtualPath/>
    </table>
    <table>
      <hub>hub_customer_sts</hub>
      <link/>
      <attributes>
        <name>name</name>
        <description>Customer name</description>
        <dataType>String</dataType>
        <length>50</length>
        <precision/>
        <includeInChangeDataCapture>Y</includeInChangeDataCapture>
      </attributes>
      <attributes>
        <name>email</name>
        <description>Customer email</description>
        <dataType>String</dataType>
        <length>50</length>
        <precision/>
        <includeInChangeDataCapture>Y</includeInChangeDataCapture>
      </attributes>
      <attributes>
        <name>address</name>
        <description>Address</description>
        <dataType>String</dataType>
        <length>50</length>
        <precision/>
        <includeInChangeDataCapture>Y</includeInChangeDataCapture>
      </attributes>
      <attributes>
        <name>city</name>
        <description>City</description>
        <dataType>String</dataType>
        <length>50</length>
        <precision/>
        <includeInChangeDataCapture>Y</includeInChangeDataCapture>
      </attributes>
      <drivingKey/>
      <recordSource>CRM-customer</recordSource>
      <statusTrackingEnabled>Y</statusTrackingEnabled>
      <statusTableName>sts_customer</statusTableName>
      <statusFieldName>record_status</statusFieldName>
      <activeStatusValue>ACTIVE</activeStatusValue>
      <deletedStatusValue>DELETED</deletedStatusValue>
      <tableName>sat_customer_sts</tableName>
      <description>Descriptive satellite with optional STS</description>
      <tableType>SATELLITE</tableType>
      <xloc>304</xloc>
      <yloc>48</yloc>
      <name>sat_customer_sts</name>
      <virtualPath/>
    </table>
  </tables>
  <notes/>
  <name>status-tracking</name>
</data-vault-model>
