<?xml version="1.0" encoding="UTF-8"?>
<workflow>
  <name>update-string-collation</name>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>SQL Server / PostgreSQL: French collation on source BK vs default vault target — exercises auto ORDER BY COLLATE</description>
  <created_user>-</created_user>
  <modified_user>-</modified_user>
  <created_date>2026/07/12 12:00:00.000</created_date>
  <modified_date>2026/07/12 12:00:00.000</modified_date>
  <parameters>
    <parameter>
      <name>OUTPUT_COPIES</name>
      <description>Valid in the current workflow</description>
      <default_value>1</default_value>
    </parameter>
    <parameter>
      <name>PIPELINE_COPIES</name>
      <description>Valid in the current workflow</description>
      <default_value>3</default_value>
    </parameter>
    <parameter>
      <name>METRICS_FOLDER</name>
      <description>Valid in the current workflow</description>
      <default_value>${PROJECT_HOME}/metrics</default_value>
    </parameter>
    <parameter>
      <name>DV_INITIAL_LOAD_DATE</name>
      <description>Fixed load date for initial Data Vault Update actions</description>
      <default_value>2024/01/01 00:00:00.000</default_value>
    </parameter>
    <parameter>
      <name>DV_UPDATE_LOAD_DATE</name>
      <description>Fixed load date for incremental Data Vault Update actions</description>
      <default_value>2024/02/01 00:00:00.000</default_value>
    </parameter>
  </parameters>
  <actions>
    <action>
      <repeat>N</repeat>
      <schedulerType>0</schedulerType>
      <intervalSeconds>0</intervalSeconds>
      <intervalMinutes>60</intervalMinutes>
      <DayOfMonth>1</DayOfMonth>
      <weekDay>1</weekDay>
      <minutes>0</minutes>
      <hour>12</hour>
      <doNotWaitOnFirstExecution>N</doNotWaitOnFirstExecution>
      <name>Start</name>
      <description/>
      <type>SPECIAL</type>
      <attributes/>
      <xloc>48</xloc>
      <yloc>48</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <sql>DROP TABLE IF EXISTS hub_item_collation;
DROP TABLE IF EXISTS sat_item_collation;
</sql>
      <connection>Vault</connection>
      <useVariableSubstitution>N</useVariableSubstitution>
      <sqlfromfile>N</sqlfromfile>
      <sqlfilename/>
      <sqlfilename_encoding/>
      <sendOneStatement>N</sendOneStatement>
      <name>drop vault tables</name>
      <description/>
      <type>SQL</type>
      <attributes/>
      <xloc>192</xloc>
      <yloc>48</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <name>sqlserver source?</name>
      <description>SQL Server uses NVARCHAR + French_CI_AS</description>
      <type>EVAL</type>
      <attributes/>
      <script>var dbType = parent_workflow.getVariable("DB_TYPE");
if (dbType == null) {
  dbType = "";
}
dbType = ("" + dbType).toLowerCase();
dbType == "sqlserver" || dbType == "mssql";
</script>
      <parallel>N</parallel>
      <xloc>352</xloc>
      <yloc>48</yloc>
      <attributes_hac/>
    </action>
    <action>
      <sql>DROP TABLE IF EXISTS item_collation;
CREATE TABLE item_collation (
  item_code NVARCHAR(50) COLLATE French_CI_AS NOT NULL,
  description NVARCHAR(100) COLLATE French_CI_AS NULL,
  record_source NVARCHAR(20) COLLATE French_CI_AS NULL
);
</sql>
      <connection>CRM</connection>
      <useVariableSubstitution>N</useVariableSubstitution>
      <sqlfromfile>N</sqlfromfile>
      <sqlfilename/>
      <sqlfilename_encoding/>
      <sendOneStatement>N</sendOneStatement>
      <name>create NVARCHAR source</name>
      <description>SQL Server: NVARCHAR + French_CI_AS so vault VARCHAR targets trigger auto COLLATE</description>
      <type>SQL</type>
      <attributes/>
      <xloc>528</xloc>
      <yloc>16</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <name>postgres source?</name>
      <description>PostgreSQL uses VARCHAR + ICU French collation</description>
      <type>EVAL</type>
      <attributes/>
      <script>var dbType = parent_workflow.getVariable("DB_TYPE");
if (dbType == null) {
  dbType = "";
}
dbType = ("" + dbType).toLowerCase();
// empty = local/default postgres in docker-postgres
dbType == "" || dbType == "postgres" || dbType == "postgresql";
</script>
      <parallel>N</parallel>
      <xloc>528</xloc>
      <yloc>80</yloc>
      <attributes_hac/>
    </action>
    <action>
      <sql>DROP TABLE IF EXISTS item_collation;
CREATE TABLE item_collation (
  item_code VARCHAR(50) COLLATE "fr-FR-x-icu" NOT NULL,
  description VARCHAR(100) COLLATE "fr-FR-x-icu" NULL,
  record_source VARCHAR(20) COLLATE "fr-FR-x-icu" NULL
);
</sql>
      <connection>CRM</connection>
      <useVariableSubstitution>N</useVariableSubstitution>
      <sqlfromfile>N</sqlfromfile>
      <sqlfilename/>
      <sqlfilename_encoding/>
      <sendOneStatement>N</sendOneStatement>
      <name>create Postgres ICU source</name>
      <description>PostgreSQL: VARCHAR + fr-FR-x-icu so vault default collation targets trigger auto COLLATE</description>
      <type>SQL</type>
      <attributes/>
      <xloc>704</xloc>
      <yloc>80</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <name>Success skip unsupported</name>
      <description>Skip string-collation suite on engines without this scenario</description>
      <type>SUCCESS</type>
      <attributes/>
      <xloc>704</xloc>
      <yloc>144</yloc>
      <parallel>N</parallel>
      <attributes_hac/>
    </action>
    <action>
      <filename>${PROJECT_HOME}/tests/sqlserver-collation/load-item-collation1.hpl</filename>
      <params_from_previous>N</params_from_previous>
      <exec_per_row>N</exec_per_row>
      <clear_rows>N</clear_rows>
      <clear_files>N</clear_files>
      <create_parent_folder>N</create_parent_folder>
      <set_logfile>N</set_logfile>
      <set_append_logfile>N</set_append_logfile>
      <add_date>N</add_date>
      <add_time>N</add_time>
      <loglevel>Basic</loglevel>
