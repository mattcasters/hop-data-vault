  <transform>
    <type>TableInput</type>
    <name>read_open_customer_360_bv</name>
    <sql>SELECT customer_hk, cust_segment, cust_loyalty_tier, cust_demo_score, cust_email, cust_phone, cust_address, cust_city, cust_postal_code, cust_newsletter, cust_channel, cust_language, x_record_source, x_load_ts
FROM customer_360_bv
WHERE x_to_ts = TIMESTAMP '9999-12-31 23:59:59' AND customer_hk IN (
  SELECT customer_hk
  FROM sat_customer_demo
  WHERE x_load_ts > COALESCE((
    SELECT MAX(x_load_ts)
    FROM customer_360_bv
  ), TIMESTAMP '1900-01-01 00:00:00')
  UNION
  SELECT customer_hk
  FROM sat_customer_contact
  WHERE x_load_ts > COALESCE((
    SELECT MAX(x_load_ts)
    FROM customer_360_bv
  ), TIMESTAMP '1900-01-01 00:00:00')
  UNION
  SELECT customer_hk
  FROM sat_customer_address
  WHERE x_load_ts > COALESCE((
    SELECT MAX(x_load_ts)
    FROM customer_360_bv
  ), TIMESTAMP '1900-01-01 00:00:00')
  UNION
  SELECT customer_hk
  FROM sat_customer_prefs
  WHERE x_load_ts > COALESCE((
    SELECT MAX(x_load_ts)
    FROM customer_360_bv
  ), TIMESTAMP '1900-01-01 00:00:00')
)
ORDER BY customer_hk, x_load_ts</sql>
