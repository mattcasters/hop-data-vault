  <transform>
    <type>ScriptValueMod</type>
    <name>ids, amount, price</name>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
function getRandomInt(min, max) {
    min = Math.ceil(min);
    max = Math.floor(max);
    return Math.floor(Math.random() * (max - min + 1)) + min;
}

var product_id = getRandomInt(1000, 5000);
var customer_id = getRandomInt(100000, 350000);
var amount = getRandomInt(1, 10);
var price = getRandomInt(100, 4000)/100;
</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>product_id</name>
        <rename>product_id</rename>
        <type>Integer</type>
        <length>7</length>
        <precision>0</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>customer_id</name>
