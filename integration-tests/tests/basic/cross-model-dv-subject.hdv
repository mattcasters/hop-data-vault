<data-vault-model>
  <filename>${PROJECT_HOME}/tests/basic/cross-model-dv-subject.hdv</filename>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>Subject-area model referencing shared hubs from another .hdv file</description>
  <configuration>
    <targetDatabase>Vault</targetDatabase>
    <dataCatalogConnection>local-catalog</dataCatalogConnection>
    <hashAlgorithm>MD5</hashAlgorithm>
    <hashKeyDataType>STRING</hashKeyDataType>
    <loadDateField>x_load_ts</loadDateField>
    <recordSourceField>x_record_source</recordSourceField>
    <recordSourceFieldLength>100</recordSourceFieldLength>
    <targetTableBatchSize>1000</targetTableBatchSize>
    <targetTableParallelCopies>1</targetTableParallelCopies>
  </configuration>
  <tables>
    <table>
      <referencedTableName>hub_customer</referencedTableName>
      <referencedModelFilename>shared-dv-core.hdv</referencedModelFilename>
      <referencedTableType>HUB</referencedTableType>
      <tableName>hub_customer</tableName>
      <tableType>TABLE_REFERENCE</tableType>
      <xloc>64</xloc>
      <yloc>64</yloc>
      <name>hub_customer</name>
    </table>
    <table>
      <referencedTableName>hub_order</referencedTableName>
      <referencedModelFilename>shared-dv-core.hdv</referencedModelFilename>
      <referencedTableType>HUB</referencedTableType>
      <tableName>hub_order</tableName>
      <tableType>TABLE_REFERENCE</tableType>
      <xloc>64</xloc>
      <yloc>192</yloc>
      <name>hub_order</name>
    </table>
    <table>
      <referencedTableName>hub_product</referencedTableName>
      <referencedModelFilename>shared-dv-core.hdv</referencedModelFilename>
      <referencedTableType>HUB</referencedTableType>
      <tableName>hub_product</tableName>
      <tableType>TABLE_REFERENCE</tableType>
      <xloc>64</xloc>
      <yloc>320</yloc>
      <name>hub_product</name>
    </table>
    <table>
      <hubNames>hub_customer</hubNames>
      <hubNames>hub_order</hubNames>
      <hubNames>hub_product</hubNames>
      <linkHubSources>
        <linkHubSource>
          <source>CRM-order</source>
          <hubSourceKeyFields>
            <hubSourceKeyField>
              <hubName>hub_customer</hubName>
              <businessKeySources>
                <businessKeySource>
                  <businessKeyField>customer_id</businessKeyField>
                  <sourceFieldName>customer_id</sourceFieldName>
                </businessKeySource>
              </businessKeySources>
            </hubSourceKeyField>
            <hubSourceKeyField>
              <hubName>hub_order</hubName>
              <businessKeySources>
                <businessKeySource>
                  <businessKeyField>order_id</businessKeyField>
                  <sourceFieldName>order_id</sourceFieldName>
                </businessKeySource>
              </businessKeySources>
            </hubSourceKeyField>
            <hubSourceKeyField>
              <hubName>hub_product</hubName>
              <businessKeySources>
                <businessKeySource>
                  <businessKeyField>product_id</businessKeyField>
                  <sourceFieldName>product_id</sourceFieldName>
                </businessKeySource>
              </businessKeySources>
            </hubSourceKeyField>
          </hubSourceKeyFields>
        </linkHubSource>
      </linkHubSources>
      <linkHashKeyFieldName>lnk_customer_order_hk</linkHashKeyFieldName>
      <tableName>lnk_customer_order</tableName>
      <tableType>LINK</tableType>
      <integrationMode>HOP_MANAGED</integrationMode>
      <xloc>320</xloc>
      <yloc>192</yloc>
      <name>lnk_customer_order</name>
    </table>
  </tables>
  <notes/>
  <name>cross-model-dv-subject</name>
</data-vault-model>