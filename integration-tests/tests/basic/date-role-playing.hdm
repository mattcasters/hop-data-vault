<dimensional-model>
  <filename>${PROJECT_HOME}/tests/basic/date-role-playing.hdm</filename>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>Date dimension with role-playing aliases on an order fact</description>
  <configuration>
    <targetDatabase>Vault</targetDatabase>
    <dimKeyField>dim_key</dimKeyField>
    <versionField>version</versionField>
    <dateFromField>date_from</dateFromField>
    <dateToField>date_to</dateToField>
    <loadDateField>load_dt</loadDateField>
    <currentFlagField>is_current</currentFlagField>
    <openStartSentinel>1900-01-01 00:00:00</openStartSentinel>
    <openEndSentinel>9999-12-31 23:59:59</openEndSentinel>
    <targetTableBatchSize>1000</targetTableBatchSize>
    <targetTableParallelCopies>1</targetTableParallelCopies>
  </configuration>
  <tables>
    <table>
      <sourceSql>SELECT date_key, full_date, year FROM stg_date</sourceSql>
      <scdType>TYPE1</scdType>
      <natural_keys>
        <natural_key>
          <fieldName>date_key</fieldName>
        </natural_key>
      </natural_keys>
      <attributes>
        <attribute>
          <fieldName>full_date</fieldName>
          <scdUpdatePolicy>TYPE1</scdUpdatePolicy>
        </attribute>
        <attribute>
          <fieldName>year</fieldName>
          <scdUpdatePolicy>TYPE1</scdUpdatePolicy>
        </attribute>
      </attributes>
      <outriggers/>
      <tableName>d_date</tableName>
      <description>Calendar date dimension</description>
      <tableType>DIMENSION</tableType>
      <xloc>64</xloc>
      <yloc>64</yloc>
      <name>dim_date</name>
    </table>
    <table>
      <referencedDimensionName>dim_date</referencedDimensionName>
      <tableName>d_date</tableName>
      <description>Order date role</description>
      <tableType>DIMENSION_ALIAS</tableType>
      <xloc>288</xloc>
      <yloc>32</yloc>
      <name>dim_order_date</name>
    </table>
    <table>
      <referencedDimensionName>dim_date</referencedDimensionName>
      <tableName>d_date</tableName>
      <description>Shipment date role</description>
      <tableType>DIMENSION_ALIAS</tableType>
      <xloc>288</xloc>
      <yloc>160</yloc>
      <name>dim_shipment_date</name>
    </table>
    <table>
      <sourceSql>SELECT order_id, order_date, shipping_date, amount FROM stg_orders</sourceSql>
      <dimension_roles>
        <dimension_role>
          <dimensionTableName>dim_order_date</dimensionTableName>
          <foreignKeyColumn>order_date_key</foreignKeyColumn>
          <sourceFieldName>order_date</sourceFieldName>
          <truncateToDateKey>true</truncateToDateKey>
        </dimension_role>
        <dimension_role>
          <dimensionTableName>dim_shipment_date</dimensionTableName>
          <foreignKeyColumn>shipment_date_key</foreignKeyColumn>
          <sourceFieldName>shipping_date</sourceFieldName>
          <truncateToDateKey>true</truncateToDateKey>
        </dimension_role>
      </dimension_roles>
      <measures>
        <measure>
          <fieldName>amount</fieldName>
          <additive>Y</additive>
        </measure>
      </measures>
      <tableName>f_orders</tableName>
      <description>Orders fact with multiple date roles</description>
      <tableType>FACT</tableType>
      <xloc>544</xloc>
      <yloc>96</yloc>
      <name>fact_orders</name>
    </table>
  </tables>
  <notes/>
  <name>date-role-playing</name>
</dimensional-model>