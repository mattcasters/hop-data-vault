        </attribute>
        <attribute>
          <sourceFieldName>birthdate</sourceFieldName>
          <fieldName>birthdate_hist</fieldName>
          <scdUpdatePolicy>TYPE2</scdUpdatePolicy>
        </attribute>
        <attribute>
          <fieldName>patient_name</fieldName>
          <scdUpdatePolicy>TYPE1</scdUpdatePolicy>
        </attribute>
      </attributes>
      <outriggers/>
      <tableName>d_patient</tableName>
      <description>Hybrid patient dimension (birthdate punch-through + historized)</description>
      <tableType>DIMENSION</tableType>
      <sourceSql>SELECT patient_id, birthdate, patient_name FROM stg_patient</sourceSql>
      <xloc>944</xloc>
      <yloc>496</yloc>
      <name>dim_patient</name>
    </table>
    <table>
      <key_fields>
        <key_field>
          <fieldName>promo_flag</fieldName>
