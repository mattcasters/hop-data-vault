<dimensional-model>
  <filename>/home/matt/git/mattcasters/hop-data-vault/integration-tests/tests//basic/extended-catalog.hdm</filename>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>Extended Kimball catalog fixture for Phase C pipeline tests</description>
  <configuration>
    <targetDatabase>Vault</targetDatabase>
    <dimKeyField>dim_key</dimKeyField>
    <versionField>version</versionField>
    <dateFromField>date_from</dateFromField>
    <dateToField>date_to</dateToField>
    <loadDateField>load_dt</loadDateField>
    <currentFlagField>is_current</currentFlagField>
    <openStartSentinel>1900-01-01 00:00:00</openStartSentinel>
    <openEndSentinel>9999-12-31 23:59:59</openEndSentinel>
    <dimensionPipelineNamePrefix>dm-dim-</dimensionPipelineNamePrefix>
    <junkDimensionPipelineNamePrefix>dm-junk-</junkDimensionPipelineNamePrefix>
    <bridgePipelineNamePrefix>dm-bridge-</bridgePipelineNamePrefix>
    <factPipelineNamePrefix>dm-fact-</factPipelineNamePrefix>
    <targetTableBatchSize>1000</targetTableBatchSize>
    <targetTableParallelCopies>1</targetTableParallelCopies>
  </configuration>
  <tables>
    <table>
      <scdType>TYPE3</scdType>
      <natural_keys>
        <natural_key>
          <fieldName>customer_id</fieldName>
        </natural_key>
      </natural_keys>
      <attributes>
        <attribute>
          <fieldName>customer_name</fieldName>
          <scdUpdatePolicy>TYPE3_CURRENT</scdUpdatePolicy>
        </attribute>
        <attribute>
          <fieldName>city</fieldName>
          <scdUpdatePolicy>TYPE3_PREVIOUS</scdUpdatePolicy>
          <previousFieldName>city_prev</previousFieldName>
        </attribute>
      </attributes>
      <outriggers/>
      <tableName>d_customer</tableName>
      <description>SCD3 customer dimension</description>
      <tableType>DIMENSION</tableType>
      <sourceSql>SELECT customer_id, customer_name, city FROM stg_customer</sourceSql>
      <xloc>304</xloc>
      <yloc>496</yloc>
      <name>dim_customer</name>
    </table>
    <table>
      <scdType>TYPE1</scdType>
      <natural_keys>
        <natural_key>
          <fieldName>product_id</fieldName>
        </natural_key>
      </natural_keys>
      <attributes>
        <attribute>
          <fieldName>product_name</fieldName>
          <scdUpdatePolicy>TYPE1</scdUpdatePolicy>
        </attribute>
      </attributes>
      <outriggers/>
      <tableName>d_product</tableName>
      <description>Product dimension</description>
      <tableType>DIMENSION</tableType>
      <sourceSql>SELECT product_id, product_name FROM stg_product</sourceSql>
      <xloc>624</xloc>
      <yloc>496</yloc>
      <name>dim_product</name>
    </table>
    <table>
      <natural_keys>
        <natural_key>
          <fieldName>patient_id</fieldName>
        </natural_key>
      </natural_keys>
      <attributes>
        <attribute>
          <sourceFieldName>birthdate</sourceFieldName>
