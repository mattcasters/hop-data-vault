<data-vault-model>
  <filename>${PROJECT_HOME}/tests/basic/shared-dv-core.hdv</filename>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>Shared core hubs for cross-model Data Vault reference tests</description>
  <configuration>
    <targetDatabase>Vault</targetDatabase>
    <dataCatalogConnection>local-catalog</dataCatalogConnection>
    <hashAlgorithm>MD5</hashAlgorithm>
    <hashKeyDataType>STRING</hashKeyDataType>
    <loadDateField>x_load_ts</loadDateField>
    <recordSourceField>x_record_source</recordSourceField>
    <recordSourceFieldLength>100</recordSourceFieldLength>
    <targetTableBatchSize>1000</targetTableBatchSize>
    <targetTableParallelCopies>1</targetTableParallelCopies>
  </configuration>
  <tables>
    <table>
      <businessKeys>
        <name>customer_id</name>
        <dataType>Integer</dataType>
        <length>9</length>
        <sourceFieldName>customer_id</sourceFieldName>
        <recordSourceName>CRM-customer</recordSourceName>
      </businessKeys>
      <hashKeyFieldName>customer_hk</hashKeyFieldName>
      <recordSources>
        <recordSource>CRM-customer</recordSource>
      </recordSources>
      <tableName>hub_customer</tableName>
      <tableType>HUB</tableType>
      <integrationMode>HOP_MANAGED</integrationMode>
      <xloc>32</xloc>
      <yloc>32</yloc>
      <name>hub_customer</name>
    </table>
    <table>
      <businessKeys>
        <name>product_id</name>
        <dataType>String</dataType>
        <length>7</length>
        <sourceFieldName>product_id</sourceFieldName>
        <recordSourceName>CRM-product</recordSourceName>
      </businessKeys>
      <hashKeyFieldName>product_hk</hashKeyFieldName>
      <recordSources>
        <recordSource>CRM-product</recordSource>
      </recordSources>
      <tableName>hub_product</tableName>
      <tableType>HUB</tableType>
      <integrationMode>HOP_MANAGED</integrationMode>
      <xloc>32</xloc>
      <yloc>160</yloc>
      <name>hub_product</name>
    </table>
    <table>
      <businessKeys>
        <name>order_id</name>
        <dataType>String</dataType>
        <length>7</length>
        <sourceFieldName>order_id</sourceFieldName>
        <recordSourceName>CRM-order</recordSourceName>
      </businessKeys>
      <hashKeyFieldName>order_hk</hashKeyFieldName>
      <recordSources>
        <recordSource>CRM-order</recordSource>
      </recordSources>
      <tableName>hub_order</tableName>
      <tableType>HUB</tableType>
      <integrationMode>HOP_MANAGED</integrationMode>
      <xloc>32</xloc>
      <yloc>288</yloc>
      <name>hub_order</name>
    </table>
  </tables>
  <notes/>
  <name>shared-dv-core</name>
</data-vault-model>