<dimensional-model>
  <filename>${PROJECT_HOME}/tests/basic/shared-conformed.hdm</filename>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>Shared conformed dimensions for cross-model alias tests</description>
  <configuration>
    <targetDatabase>Vault</targetDatabase>
    <dimKeyField>dim_key</dimKeyField>
    <versionField>version</versionField>
    <dateFromField>date_from</dateFromField>
    <dateToField>date_to</dateToField>
    <loadDateField>load_dt</loadDateField>
    <currentFlagField>is_current</currentFlagField>
    <openStartSentinel>1900-01-01 00:00:00</openStartSentinel>
    <openEndSentinel>9999-12-31 23:59:59</openEndSentinel>
    <targetTableBatchSize>1000</targetTableBatchSize>
    <targetTableParallelCopies>1</targetTableParallelCopies>
  </configuration>
  <tables>
    <table>
      <sourceSql>SELECT date_key, full_date, year, load_dt FROM stg_date</sourceSql>
      <scdType>TYPE1</scdType>
      <natural_keys>
        <natural_key>
          <fieldName>date_key</fieldName>
        </natural_key>
      </natural_keys>
      <attributes>
        <attribute>
          <fieldName>full_date</fieldName>
          <scdUpdatePolicy>TYPE1</scdUpdatePolicy>
        </attribute>
        <attribute>
          <fieldName>year</fieldName>
          <scdUpdatePolicy>TYPE1</scdUpdatePolicy>
        </attribute>
      </attributes>
      <outriggers/>
      <tableName>d_date</tableName>
      <description>Shared calendar date dimension</description>
      <tableType>DIMENSION</tableType>
      <xloc>64</xloc>
      <yloc>64</yloc>
      <name>dim_date</name>
    </table>
    <table>
      <sourceSql>SELECT customer_id, customer_name, load_dt FROM stg_customer</sourceSql>
      <scdType>TYPE1</scdType>
      <natural_keys>
        <natural_key>
          <fieldName>customer_id</fieldName>
        </natural_key>
      </natural_keys>
      <attributes>
        <attribute>
          <fieldName>customer_name</fieldName>
          <scdUpdatePolicy>TYPE1</scdUpdatePolicy>
        </attribute>
      </attributes>
      <outriggers/>
      <tableName>d_customer</tableName>
      <description>Shared customer dimension</description>
      <tableType>DIMENSION</tableType>
      <xloc>64</xloc>
      <yloc>224</yloc>
      <name>dim_customer</name>
    </table>
    <table>
      <sourceSql>SELECT product_id, product_name, load_dt FROM stg_product</sourceSql>
      <scdType>TYPE1</scdType>
      <natural_keys>
        <natural_key>
          <fieldName>product_id</fieldName>
        </natural_key>
      </natural_keys>
      <attributes>
        <attribute>
          <fieldName>product_name</fieldName>
          <scdUpdatePolicy>TYPE1</scdUpdatePolicy>
        </attribute>
      </attributes>
      <outriggers/>
      <tableName>d_product</tableName>
      <description>Shared product dimension</description>
      <tableType>DIMENSION</tableType>
      <xloc>64</xloc>
      <yloc>384</yloc>
      <name>dim_product</name>
    </table>
  </tables>
  <notes/>
  <name>shared-conformed</name>
</dimensional-model>